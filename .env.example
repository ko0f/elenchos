# Copy to .env and uncomment what you need.
# See README.md for full list.

# Data directory (default ~/.elenchos)
# ELENCHOS_DATA_DIR=~/.elenchos

# --- Ollama (default http://localhost:11434) ---
# ELENCHOS_OLLAMA_BASE_URL=http://localhost:11434
# ELENCHOS_OLLAMA_API_KEY=

# --- LM Studio (default http://localhost:1234/v1) ---
# ELENCHOS_LMSTUDIO_BASE_URL=http://localhost:1234/v1
# ELENCHOS_LMSTUDIO_API_KEY=

# Second LM Studio host (requires providers.lmstudio-remote in config.yaml)
# ELENCHOS_LMSTUDIO_REMOTE_BASE_URL=http://192.168.1.50:1234/v1

# --- OpenRouter (default https://openrouter.ai/api/v1) ---
# OPENROUTER_API_KEY=          # also accepted without ELENCHOS_ prefix
# ELENCHOS_OPENROUTER_API_KEY=
# ELENCHOS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Legacy LM Studio runner (elenchos run --prompts only)
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_API_KEY=not-needed
# LM_STUDIO_MODEL=
